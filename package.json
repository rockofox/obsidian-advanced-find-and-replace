{
	"type": "module",
	"name": "advanced-find-and-replace",
	"version": "0.0.1",
	"description": "An advanced tool for finding and replacing text across all files in your vault, with live preview and regular expression support.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "NODE_OPTIONS=--max-old-space-size=4096 vitest",
		"test:ui": "NODE_OPTIONS=--max-old-space-size=4096 vitest --ui",
		"test:coverage": "NODE_OPTIONS=--max-old-space-size=4096 vitest --coverage"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.30.1",
		"@types/node": "^18.0.0",
		"@typescript-eslint/eslint-plugin": "^8.58.2",
		"@typescript-eslint/parser": "^8.58.2",
		"@vitest/coverage-v8": "^1.6.1",
		"@vitest/ui": "^1.0.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"eslint": "^9.30.1",
		"eslint-plugin-no-unsanitized": "^4.1.5",
		"eslint-plugin-obsidianmd": "^0.2.3",
		"happy-dom": "^20.0.11",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.2",
		"vitest": "^1.0.0"
	}
}
